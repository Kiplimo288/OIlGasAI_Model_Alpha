# ── Hugging Face ──────────────────────────────────────────────
HF_TOKEN=hf_your_token_here
HF_MODEL_ID=OilgasAI/OilGasAI-Model-Alpha

# Set to "true" to use HF Inference API instead of local GPU
USE_HF_API=false

# ── Model settings ────────────────────────────────────────────
# Quantization: 4bit | 8bit | none
QUANTIZATION=4bit
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
DEVICE=auto

# ── RAG settings ──────────────────────────────────────────────
FAISS_INDEX_PATH=./rag/index/oilgas_faiss.index
EMBEDDINGS_MODEL=BAAI/bge-large-en-v1.5
RAG_TOP_K=5

# ── API settings ──────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=your_api_key_here
DEBUG=false
